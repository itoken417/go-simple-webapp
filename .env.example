APP_NAME=MyApp
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
# セットアップ時に暗号化され、.env には SMTP_PASSWORD_ENCRYPTED / SMTP_PASSWORD_SALT として保存される
SMTP_PASSWORD=yourpassword
SMTP_FROM=user@example.com
SYSTEM_TO=user@example.com
ERROR_TO=admin@example.com
# base64 / quoted-printable / 未設定（そのまま送信）
MAIL_ENCODING=base64
